{
  "name": "vaktija",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "build": "ng build && ngsw-config ./dist/Vaktija/browser ./ngsw-config.json && node -e \"require('fs').copyFileSync('node_modules/@angular/service-worker/ngsw-worker.js','dist/Vaktija/browser/ngsw-worker.js')\"",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "og-banner": "node scripts/make-og-banner.mjs"
  },
  "private": true,
  "packageManager": "npm@10.9.3",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "~21.2.0",
    "@kmaslesa/vaktija": "^1.0.5",
    "geographiclib-geodesic": "^2.2.0",
    "geomagnetism": "^0.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
